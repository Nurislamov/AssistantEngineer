{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assistantengineer.local/schemas/goal-run-report.schema.json",
  "title": "AssistantEngineer Goal Run Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "goalId",
    "title",
    "sourceBranch",
    "targetBranch",
    "scope",
    "outOfScope",
    "constraints",
    "preflight",
    "phases",
    "finalAudit",
    "warnings",
    "blockers",
    "generatedArtifacts"
  ],
  "properties": {
    "goalId": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "sourceBranch": { "type": "string", "minLength": 1 },
    "targetBranch": { "type": "string", "minLength": 1 },
    "scope": { "$ref": "#/$defs/nonEmptyStrings" },
    "outOfScope": { "$ref": "#/$defs/strings" },
    "constraints": { "$ref": "#/$defs/nonEmptyStrings" },
    "preflight": {
      "type": "object",
      "additionalProperties": false,
      "required": ["commands"],
      "properties": {
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/command" }
        }
      }
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/phase" }
    },
    "finalAudit": { "$ref": "#/$defs/finalAudit" },
    "warnings": { "$ref": "#/$defs/strings" },
    "blockers": { "$ref": "#/$defs/strings" },
    "generatedArtifacts": { "$ref": "#/$defs/strings" }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "not_run"]
    },
    "strings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "command": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "command", "status", "evidence"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/status" },
        "evidence": { "type": "string" }
      }
    },
    "phase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "number",
        "title",
        "status",
        "deliverables",
        "acceptanceCriteria",
        "mandatoryCommands",
        "evidence"
      ],
      "properties": {
        "number": { "type": "integer", "minimum": 1 },
        "title": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/status" },
        "deliverables": { "$ref": "#/$defs/nonEmptyStrings" },
        "acceptanceCriteria": { "$ref": "#/$defs/nonEmptyStrings" },
        "mandatoryCommands": { "$ref": "#/$defs/nonEmptyStrings" },
        "evidence": { "$ref": "#/$defs/strings" }
      }
    },
    "finalAudit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "roadmapCoverage",
        "phaseCompletion",
        "changedFilesReview",
        "forbiddenFilesReview",
        "forbiddenClaimsReview",
        "secretsScan",
        "generatedArtifacts",
        "mergeReadiness"
      ],
      "properties": {
        "status": { "$ref": "#/$defs/status" },
        "roadmapCoverage": { "type": "string", "minLength": 1 },
        "phaseCompletion": { "type": "string", "minLength": 1 },
        "changedFilesReview": { "type": "string", "minLength": 1 },
        "forbiddenFilesReview": { "type": "string", "minLength": 1 },
        "forbiddenClaimsReview": { "type": "string", "minLength": 1 },
        "secretsScan": { "type": "string", "minLength": 1 },
        "generatedArtifacts": { "type": "string", "minLength": 1 },
        "mergeReadiness": { "type": "string", "minLength": 1 }
      }
    }
  }
}
