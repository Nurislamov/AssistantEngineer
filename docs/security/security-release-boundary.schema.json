    "stagingApplyEnabled",
    "ownershipBackfillExecuted",
    "dbWritePathEnabled",
    "globalEfQueryFiltersEnabled",
    "databaseRowLevelSecurityEnabled",
    "fullTenantIsolationClaimed",
    "productionSecurityCertified"
  ],
  "releaseBoundaryExpectedBooleanValues": {
    "productionApplyEnabled": false,
    "stagingApplyEnabled": false,
    "ownershipBackfillExecuted": false,
    "dbWritePathEnabled": false,
    "globalEfQueryFiltersEnabled": false,
    "databaseRowLevelSecurityEnabled": false,
    "fullTenantIsolationClaimed": false,
    "productionSecurityCertified": false
  }
}
