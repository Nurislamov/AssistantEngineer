{
  "name": "security-release-boundary",
  "version": 1,
  "requiredTopLevelFields": [
    "version",
    "lastReviewedDate",
    "stage",
    "enabledCapabilities",
    "intentionallyDisabledCapabilities",
    "allowedClaims",
    "forbiddenClaims",
    "releaseBoundary",
    "nonClaims"
  ],
  "releaseBoundaryRequiredFields": [
