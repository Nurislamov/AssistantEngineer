{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assistantengineer.local/docs/security/ownership-backfill-manual-write-path-enablement-decision.schema.json",
  "title": "OwnershipBackfillManualWritePathEnablementDecision",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "version",
    "lastReviewedDate",
    "stage",
    "productionApplyEnabled",
    "stagingApplyEnabled",
    "backfillExecution",
    "codeWritePathEnabled",
    "requiredHashes",
    "requiredApprovals",
    "decisionStatuses",
    "goCriteria",
    "noGoCriteria",
    "nonClaims"
  ],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "lastReviewedDate": { "type": "string", "format": "date" },
    "stage": { "type": "string", "const": "P6-14" },
    "productionApplyEnabled": { "type": "boolean" },
    "stagingApplyEnabled": { "type": "boolean" },
    "backfillExecution": { "type": "boolean" },
    "codeWritePathEnabled": { "type": "boolean" },
    "requiredHashes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "requiredApprovals": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "decisionStatuses": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "goCriteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "noGoCriteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "nonClaims": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
