{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AssistantEngineer tenant isolation integration matrix",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "lastReviewedDate",
    "actors",
    "resourceFamilies",
    "endpointGroups",
    "nonClaims"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "lastReviewedDate": {
      "type": "string",
      "format": "date"
    },
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "organizationId",
          "userId",
          "permissions"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "organizationId": {
            "type": [
              "integer",
              "null"
            ]
          },
          "userId": {
            "type": [
              "integer",
              "null"
            ]
          },
          "permissions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "resourceFamilies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "tenant",
          "scope"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "tenant": {
            "type": "string"
          },
          "scope": {
            "type": "string"
          }
        }
      }
    },
    "endpointGroups": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "group",
          "permission",
          "rolloutStage",
          "sameTenantExpected",
          "missingPermissionExpected",
          "crossTenantExpected",
          "anonymousExpected",
          "coveredByTests",
          "knownLimitations"
        ],
        "properties": {
          "group": {
            "type": "string"
          },
          "permission": {
            "type": "string"
          },
          "rolloutStage": {
            "type": "string"
          },
          "controllerIntegration": {
            "type": "string"
          },
          "tenantAwareQueryService": {
            "type": "boolean"
          },
          "sameTenantExpected": {
            "type": "string"
          },
          "missingPermissionExpected": {
            "type": "string"
          },
          "crossTenantExpected": {
            "type": "string"
          },
          "anonymousExpected": {
            "type": "string"
          },
          "coveredByTests": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "knownLimitations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "nonClaims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  }
}
