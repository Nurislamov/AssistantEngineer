{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Post-P6 Governance Audit",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "lastReviewedDate",
    "stage",
    "releaseBoundary",
    "findingCounts",
    "findings",
    "recommendedBacklog",
    "nonClaims"
  ],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "lastReviewedDate": { "type": "string", "format": "date" },
    "stage": { "type": "string", "const": "P7-00" },
    "releaseBoundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applyEnabled",
        "stagingApplyEnabled",
        "productionApplyEnabled",
        "backfillExecution",
        "globalEfQueryFilters",
        "databaseRowLevelSecurity",
        "fullTenantIsolationClaim"
      ],
      "properties": {
        "applyEnabled": { "type": "boolean" },
        "stagingApplyEnabled": { "type": "boolean" },
        "productionApplyEnabled": { "type": "boolean" },
        "backfillExecution": { "type": "boolean" },
        "globalEfQueryFilters": { "type": "boolean" },
        "databaseRowLevelSecurity": { "type": "boolean" },
        "fullTenantIsolationClaim": { "type": "boolean" }
      }
    },
    "findingCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["critical", "high", "medium", "low"],
      "properties": {
        "critical": { "type": "integer", "minimum": 0 },
        "high": { "type": "integer", "minimum": 0 },
        "medium": { "type": "integer", "minimum": 0 },
        "low": { "type": "integer", "minimum": 0 }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "severity",
          "title",
          "area",
          "description",
          "evidencePath",
          "recommendedAction",
          "proposedStage"
        ],
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "high", "medium", "low"] },
          "title": { "type": "string" },
          "area": { "type": "string" },
          "description": { "type": "string" },
          "evidencePath": { "type": "string" },
          "recommendedAction": { "type": "string" },
          "proposedStage": { "type": "string" }
        }
      }
    },
    "recommendedBacklog": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["item", "title", "description"],
        "properties": {
          "item": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "nonClaims": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    }
  }
}
