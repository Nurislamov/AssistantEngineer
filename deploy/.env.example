# Provider-neutral placeholders only. Copy to deploy/.env locally and never commit deploy/.env.
ASPNETCORE_ENVIRONMENT=Production
API_LOCAL_PORT=8080
FRONTEND_LOCAL_PORT=8081
HTTP_PORT=80
HTTPS_PORT=443
VITE_API_BASE_URL=http://localhost/
VITE_API_VERSION=1

ASSISTANTENGINEER_DATAPROTECTION_KEYS_PATH=/home/app/.aspnet/DataProtection-Keys
ASSISTANTENGINEER_DATAPROTECTION_CERTIFICATE_PATH=
ASSISTANTENGINEER_DATAPROTECTION_CERTIFICATE_PASSWORD=

TELEGRAM_IS_ENABLED=false
TELEGRAM_INBOUND_MODE=Polling
TELEGRAM_DELETE_WEBHOOK_ON_STARTUP=false
TELEGRAM_COMMANDS_SYNC_ON_STARTUP=true
TELEGRAM_DISPLAY_TIME_ZONE=Asia/Tashkent
TELEGRAM_OPERATOR_INBOX_ENABLED=false
TELEGRAM_OPERATOR_CHAT_ID=
TELEGRAM_OPERATOR_LOG_DIAGNOSTICS=false
TELEGRAM_SERVICE_REQUESTS_CHAT_ID=
TELEGRAM_SERVICE_REQUESTS_NOTIFY_ON_CREATE=true
TELEGRAM_POLLING_ENABLED=false
TELEGRAM_POLLING_TIMEOUT_SECONDS=50
TELEGRAM_POLLING_LIMIT=25
TELEGRAM_POLLING_DELAY_AFTER_ERROR_SECONDS=10
TELEGRAM_PROCESSED_MESSAGE_STORE_FILE_PATH=artifacts/operations/equipment-diagnostics-telegram-processed-messages.txt
TELEGRAM_PROCESSED_MESSAGE_STORE_MAX_ENTRIES=5000
TELEGRAM_ENABLE_CHAT_ID_DISCOVERY=false
TELEGRAM_BOOTSTRAP_OWNER_CHAT_ID=
TELEGRAM_ALLOWED_CHAT_ID=
TELEGRAM_ALLOWED_USERNAME=
TELEGRAM_DENIED_CHAT_ID=
AssistantEngineer__EquipmentDiagnostics__Telegram__BotToken=
AssistantEngineer__EquipmentDiagnostics__Telegram__WebhookSecret=
AssistantEngineer__EquipmentDiagnostics__Telegram__BootstrapOwnerChatId=
# Closed beta allowlist example:
# AssistantEngineer__EquipmentDiagnostics__Telegram__AllowedChatIds__0=<telegram-chat-id>
AssistantEngineer__EquipmentDiagnostics__Telegram__AllowedChatIds__0=
AssistantEngineer__EquipmentDiagnostics__Telegram__AllowedUsernames__0=
AssistantEngineer__EquipmentDiagnostics__Telegram__DeniedChatIds__0=
