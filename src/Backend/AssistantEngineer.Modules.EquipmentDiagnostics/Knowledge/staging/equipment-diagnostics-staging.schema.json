{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assistantengineer.local/schemas/equipment-diagnostics-staging.schema.json",
  "title": "AssistantEngineer Equipment Diagnostics Staging Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidates"
  ],
  "properties": {
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    }
  },
  "$defs": {
    "safeText": {
      "type": "string",
      "minLength": 1,
      "not": {
        "pattern": "(?i)(bypass|disable protection|disable protections|force run|short protection|ignore protection)"
      }
    },
    "nullableSafeText": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1,
      "not": {
        "pattern": "(?i)(bypass|disable protection|disable protections|force run|short protection|ignore protection)"
      }
    },
    "safeTextArray": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/safeText"
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manufacturer",
        "series",
        "category",
        "modelCode",
        "code",
        "title",
        "meaning",
        "severity",
        "proposedConfidence",
        "source",
        "likelyCauses",
        "diagnosticSteps",
        "requiredMeasurements",
        "safetyNotes",
        "tags",
        "promotionNotes",
        "reviewStatus"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "proposedConfidence": {
                "const": "ManualVerified"
              }
            },
            "required": [
              "proposedConfidence"
            ]
          },
          "then": {
            "properties": {
              "source": {
                "properties": {
                  "evidenceLevel": {
                    "enum": [
                      "ManualPageVerified",
                      "CrossChecked"
                    ]
                  }
                },
                "required": [
                  "evidenceLevel"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "reviewStatus": {
                "const": "ApprovedForCatalog"
              }
            },
            "required": [
              "reviewStatus"
            ]
          },
          "then": {
            "properties": {
              "source": {
                "properties": {
                  "evidenceLevel": {
                    "enum": [
                      "ManualReferenced",
                      "ManualPageVerified",
                      "CrossChecked"
                    ]
                  },
                  "manualTitle": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "required": [
                  "evidenceLevel",
                  "manualTitle"
                ]
              }
            }
          }
        }
      ],
      "properties": {
        "manufacturer": {
          "$ref": "#/$defs/safeText"
        },
        "series": {
          "$ref": "#/$defs/safeText"
        },
        "category": {
          "enum": [
            "VrfOutdoorUnit",
            "VrfIndoorUnit",
            "Chiller",
            "RooftopUnit",
            "SplitSystem",
            "AirHandlingUnit",
            "Controller",
            "Unknown"
          ]
        },
        "modelCode": {
          "$ref": "#/$defs/nullableSafeText"
        },
        "code": {
          "$ref": "#/$defs/safeText"
        },
        "title": {
          "$ref": "#/$defs/safeText"
        },
        "meaning": {
          "$ref": "#/$defs/safeText"
        },
        "severity": {
          "$ref": "#/$defs/safeText"
        },
        "proposedConfidence": {
          "enum": [
            "Unknown",
            "Low",
            "Medium",
            "High",
            "ManualVerified"
          ]
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "likelyCauses": {
          "$ref": "#/$defs/safeTextArray"
        },
        "diagnosticSteps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/diagnosticStep"
          }
        },
        "requiredMeasurements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/requiredMeasurement"
          }
        },
        "safetyNotes": {
          "$ref": "#/$defs/safeTextArray"
        },
        "tags": {
          "$ref": "#/$defs/safeTextArray"
        },
        "promotionNotes": {
          "$ref": "#/$defs/safeTextArray"
        },
        "reviewStatus": {
          "enum": [
            "Draft",
            "NeedsManualCheck",
            "ReadyForReview",
            "ApprovedForCatalog",
            "Rejected"
          ]
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceType",
        "evidenceLevel",
        "manualTitle",
        "manualVersion",
        "manualDocumentCode",
        "page",
        "section",
        "quote",
        "notes",
        "limitations",
        "applicableModels",
        "applicableSeries"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "evidenceLevel": {
                "const": "ManualPageVerified"
              }
            },
            "required": [
              "evidenceLevel"
            ]
          },
          "then": {
            "properties": {
              "manualTitle": {
                "type": "string",
                "minLength": 1
              },
              "page": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "manualTitle",
              "page"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "evidenceLevel": {
                "const": "CrossChecked"
              }
            },
            "required": [
              "evidenceLevel"
            ]
          },
          "then": {
            "properties": {
              "notes": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "notes"
            ]
          }
        }
      ],
      "properties": {
        "sourceType": {
          "enum": [
            "SeededEngineeringKnowledge",
            "ManufacturerDocumentation",
            "ServiceManual",
            "FieldObservation",
            "CrossCheckedManuals"
          ]
        },
        "evidenceLevel": {
          "enum": [
            "UnverifiedSeed",
            "ManualReferenced",
            "ManualPageVerified",
            "FieldObserved",
            "CrossChecked"
          ]
        },
        "manualTitle": {
          "$ref": "#/$defs/nullableSafeText"
        },
        "manualVersion": {
          "$ref": "#/$defs/nullableSafeText"
        },
        "manualDocumentCode": {
          "$ref": "#/$defs/nullableSafeText"
        },
        "page": {
          "$ref": "#/$defs/nullableSafeText"
        },
        "section": {
          "$ref": "#/$defs/nullableSafeText"
        },
        "quote": {
          "oneOf": [
            {
              "type": "null"
            },
            {
              "$ref": "#/$defs/safeText",
              "maxLength": 240
            }
          ]
        },
        "notes": {
          "$ref": "#/$defs/nullableSafeText"
        },
        "limitations": {
          "$ref": "#/$defs/safeTextArray"
        },
        "applicableModels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/safeText"
          }
        },
        "applicableSeries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/safeText"
          }
        }
      }
    },
    "diagnosticStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "order",
        "title",
        "instruction",
        "expectedResult",
        "ifFailedAction"
      ],
      "properties": {
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "$ref": "#/$defs/safeText"
        },
        "instruction": {
          "$ref": "#/$defs/safeText"
        },
        "expectedResult": {
          "$ref": "#/$defs/safeText"
        },
        "ifFailedAction": {
          "$ref": "#/$defs/safeText"
        }
      }
    },
    "requiredMeasurement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "unit",
        "description",
        "requiredBeforeConclusion"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/safeText"
        },
        "unit": {
          "$ref": "#/$defs/safeText"
        },
        "description": {
          "$ref": "#/$defs/safeText"
        },
        "requiredBeforeConclusion": {
          "type": "boolean"
        }
      }
    }
  }
}
