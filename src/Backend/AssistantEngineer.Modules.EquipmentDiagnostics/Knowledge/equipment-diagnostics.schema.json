{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assistantengineer.local/schemas/equipment-diagnostics.schema.json",
  "title": "AssistantEngineer Equipment Diagnostics Knowledge Catalog",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entries"
  ],
  "properties": {
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manufacturer",
        "seriesName",
        "modelCode",
        "category",
        "code",
        "title",
        "meaning",
        "severity",
        "confidence",
        "likelyCauses",
        "diagnosticSteps",
        "requiredMeasurements",
        "safetyNotes",
        "manualReferences",
        "source",
        "tags"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "confidence": {
                "const": "ManualVerified"
              }
            },
            "required": [
              "confidence"
            ]
          },
          "then": {
            "properties": {
              "source": {
                "properties": {
                  "evidenceLevel": {
                    "enum": [
                      "ManualPageVerified",
                      "CrossChecked"
                    ]
                  }
                },
                "required": [
                  "evidenceLevel"
                ]
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "source": {
                "properties": {
                  "evidenceLevel": {
                    "const": "CrossChecked"
                  }
                },
                "required": [
                  "evidenceLevel"
                ]
              }
            },
            "required": [
              "source"
            ]
          },
          "then": {
            "anyOf": [
              {
                "properties": {
                  "source": {
                    "properties": {
                      "notes": {
                        "type": "string",
                        "minLength": 1
                      }
                    },
                    "required": [
                      "notes"
                    ]
                  }
                }
              },
              {
                "properties": {
                  "manualReferences": {
                    "type": "array",
                    "minItems": 1
                  }
                },
                "required": [
                  "manualReferences"
                ]
              }
            ]
          }
        }
      ],
      "properties": {
        "manufacturer": {
          "type": "string",
          "minLength": 1
        },
        "seriesName": {
          "type": [
            "string",
            "null"
          ]
        },
        "modelCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "category": {
          "enum": [
            "VrfOutdoorUnit",
            "VrfIndoorUnit",
            "Chiller",
            "RooftopUnit",
            "SplitSystem",
            "AirHandlingUnit",
            "Controller",
            "Unknown"
          ]
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "meaning": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "enum": [
            "Unknown",
            "Low",
            "Medium",
            "High",
            "ManualVerified"
          ]
        },
        "likelyCauses": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "diagnosticSteps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/diagnosticStep"
          }
        },
        "requiredMeasurements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/requiredMeasurement"
          }
        },
        "safetyNotes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "manualReferences": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/manualReference"
          }
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceType",
        "evidenceLevel",
        "manualTitle",
        "manualVersion",
        "manualDocumentCode",
        "page",
        "section",
        "quote",
        "notes",
        "limitations",
        "applicableModels",
        "applicableSeries"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "evidenceLevel": {
                "const": "ManualPageVerified"
              }
            },
            "required": [
              "evidenceLevel"
            ]
          },
          "then": {
            "properties": {
              "manualTitle": {
                "type": "string",
                "minLength": 1
              },
              "page": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "manualTitle",
              "page"
            ]
          }
        }
      ],
      "properties": {
        "sourceType": {
          "enum": [
            "SeededEngineeringKnowledge",
            "ManufacturerDocumentation",
            "ServiceManual",
            "FieldObservation",
            "CrossCheckedManuals"
          ]
        },
        "evidenceLevel": {
          "enum": [
            "UnverifiedSeed",
            "ManualReferenced",
            "ManualPageVerified",
            "FieldObserved",
            "CrossChecked"
          ]
        },
        "manualTitle": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "manualVersion": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "manualDocumentCode": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "page": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "section": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "quote": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "notes": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "limitations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "applicableModels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "applicableSeries": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "diagnosticStep": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "order",
        "title",
        "instruction",
        "expectedResult",
        "ifFailedAction"
      ],
      "properties": {
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "instruction": {
          "type": "string",
          "minLength": 1
        },
        "expectedResult": {
          "type": "string",
          "minLength": 1
        },
        "ifFailedAction": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "requiredMeasurement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "unit",
        "description",
        "requiredBeforeConclusion"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "unit": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "requiredBeforeConclusion": {
          "type": "boolean"
        }
      }
    },
    "manualReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "manufacturer",
        "manualTitle",
        "manualVersion",
        "page",
        "notes"
      ],
      "properties": {
        "manufacturer": {
          "type": "string",
          "minLength": 1
        },
        "manualTitle": {
          "type": "string",
          "minLength": 1
        },
        "manualVersion": {
          "type": [
            "string",
            "null"
          ]
        },
        "page": {
          "type": [
            "string",
            "null"
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
