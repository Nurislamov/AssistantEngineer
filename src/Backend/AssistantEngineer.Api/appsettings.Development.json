{
    "Logging":  {
                    "LogLevel":  {
                                     "Default":  "Information",
                                     "Microsoft.AspNetCore":  "Warning"
                                 }
                },
    "ConnectionStrings":  {
                              "DefaultConnection":  "Host=localhost;Port=5432;Database=AssistantEngineerDb;Username=postgres",
                              "EngineeringWorkflowPersistence":  "Data Source=assistant-engineer-workflow.dev.db;Cache=Shared;Mode=ReadWriteCreate"
                          },
    "EngineeringWorkflowPersistence":  {
                                           "Provider":  "SQLite",
                                           "EnsureCreatedOnStartup":  true,
                                           "PayloadLimits":  {
                                                                 "Enabled":  true,
                                                                 "RequestJsonMaxBytes":  524288,
                                                                 "StateJsonMaxBytes":  1048576,
                                                                 "ResultSummaryJsonMaxBytes":  1048576,
                                                                 "DiagnosticsJsonMaxBytes":  524288,
                                                                 "ArtifactContentMaxBytes":  4194304,
                                                                 "TruncationMarker":  "[TRUNCATED_BY_ASSISTANT_ENGINEER_PAYLOAD_LIMIT]"
                                                             }
                                       },
    "EngineeringArtifacts":  {
                                 "Provider":  "InMemory",
                                 "RootPath":  "artifacts/engineering",
                                 "MaxArtifactBytes":  10485760,
                                 "EnableSha256Verification":  true
                             },
    "ApiHardening":  {
                         "Cors":  {
                                      "Enabled":  true,
                                      "PolicyName":  "ApiCors",
                                      "AllowedOrigins":  [
                                                             "http://localhost:5173",
                                                             "https://localhost:5173",
                                                             "http://localhost:3000",
                                                             "https://localhost:3000"
                                                         ],
                                      "AllowedMethods":  [
                                                             "GET",
                                                             "POST",
                                                             "PUT",
                                                             "PATCH",
                                                             "DELETE",
                                                             "OPTIONS"
                                                         ],
                                      "AllowedHeaders":  [
                                                             "Content-Type",
                                                             "Authorization",
                                                             "X-AssistantEngineer-Api-Key"
                                                         ]
                                  },
                         "RateLimiting":  {
                                               "Enabled":  true,
                                               "PermitLimit":  120,
                                               "WindowSeconds":  60,
                                               "QueueLimit":  0,
                                               "AutoReplenishment":  true,
                                               "DefaultPolicyName":  "ApiDefault",
                                               "HeavyPolicyName":  "EngineeringHeavy",
                                               "HeavyPermitLimit":  60,
                                               "HeavyWindowSeconds":  60
                                           }
                     },
    "EnergyPlus":  {
                       "ExecutablePath":  "energyplus"
                   },
    "Authentication":  {
                           "ApiKey":  {
                                          "Enabled":  false,
                                          "HeaderName":  "X-AssistantEngineer-Api-Key"
                                      }
                       },
    "ApiAuthentication":  {
                              "Enabled":  true,
                              "AllowAnonymousInDevelopment":  true,
                              "ApiKeyHeaderName":  "X-AssistantEngineer-Api-Key",
                              "RequireHttps":  false,
                              "EnableApiKeyAuthentication":  true,
                              "EnableJwtBearerAuthentication":  false,
                              "JwtAuthority":  null,
                              "JwtAudience":  null
                          },
    "ApiAuthorization":  {
                             "Enabled":  false,
                             "EnableEndpointProtectionPilot":  false,
                             "EnableReadEndpointProtectionPilot":  false,
                             "RequireProjectReadAuthorization":  false,
                             "RequireBuildingReadAuthorization":  false,
                             "EnableWriteEndpointProtectionPilot":  false,
                             "RequireProjectWriteAuthorization":  false,
                             "RequireBuildingWriteAuthorization":  false,
                             "EnableExecutionEndpointProtectionPilot":  false,
                             "RequireWorkflowExecuteAuthorization":  false,
                             "RequireCalculationRunAuthorization":  false,
                             "ReturnNotFoundForTenantMismatch":  false,
                             "AllowAnonymousInDevelopment":  true
                         },
    "ApiRateLimiting":  {
                            "Enabled":  false,
                            "AllowRelaxedLimitsInDevelopment":  true,
                            "UseAuthenticatedPrincipalPartitioning":  true,
                            "UseOrganizationPartitioning":  true,
                            "UseApiKeyFingerprintPartitioning":  true,
                            "DefaultPolicyName":  "AssistantEngineerDefault",
                            "AnonymousPublicReadLimitPerMinute":  120,
                            "AnonymousCalculationRunLimitPerMinute":  10,
                            "AuthenticatedCalculationRunLimitPerMinute":  60,
                            "OrganizationCalculationRunLimitPerMinute":  300,
                            "WorkflowExecuteLimitPerMinute":  30,
                            "ReportGenerateLimitPerMinute":  20
                        },
    "EngineeringCalculationJobs":  {
                                       "Worker":  {
                                                      "Enabled":  true,
                                                      "PollIntervalSeconds":  5,
                                                      "BatchSize":  3,
                                                      "LeaseDurationSeconds":  300,
                                                      "StaleRunningJobRecoveryEnabled":  false
                                                  }
                                   },
    "EngineeringIdempotency":  {
                                   "Enabled":  true,
                                   "TtlMinutes":  1440,
                                   "MaxEntries":  2000,
                                   "MaxCachedResponseBytes":  524288
                               },
    "Identity":  {
                     "AuditLog":  {
                                      "Enabled":  false,
                                      "WriteAuthorizationDeniedEvents":  true,
                                      "WriteArtifactEvents":  true,
                                      "MaxMetadataValueLength":  512,
                                      "Provider":  "InMemory"
                                  }
                               }
}
