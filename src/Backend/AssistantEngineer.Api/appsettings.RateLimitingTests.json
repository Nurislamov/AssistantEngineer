{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=AssistantEngineerTests;Username=postgres"
  },
  "EngineeringWorkflowPersistence": {
    "Provider": "InMemory",
    "EnsureCreatedOnStartup": true
  },
  "EnergyPlus": {
    "UseDocker": false,
    "ExecutablePath": "energyplus"
  },
  "Authentication": {
    "ApiKey": {
      "Enabled": false,
      "HeaderName": "X-AssistantEngineer-Api-Key"
    }
  },
  "ApiHardening": {
    "Cors": {
      "Enabled": false,
      "PolicyName": "ApiCors",
      "AllowedOrigins": [],
      "AllowedMethods": [
        "GET",
        "POST",
        "PUT",
        "PATCH",
        "DELETE",
        "OPTIONS"
      ],
      "AllowedHeaders": [
        "Content-Type",
        "Authorization",
        "X-AssistantEngineer-Api-Key",
        "X-Correlation-ID"
      ]
    },
    "RateLimiting": {
      "Enabled": true,
      "PermitLimit": 1000,
      "WindowSeconds": 60,
      "QueueLimit": 0,
      "AutoReplenishment": true,
      "DefaultPolicyName": "ApiDefault",
      "HeavyPolicyName": "EngineeringHeavy",
      "HeavyPermitLimit": 1,
      "HeavyWindowSeconds": 60
    }
  },
  "EngineeringCalculationJobs": {
    "Worker": {
      "Enabled": false,
      "PollIntervalSeconds": 5,
      "BatchSize": 3
    }
  }
}
