{
    "ConnectionStrings":  {
                              "DefaultConnection":  "Host=localhost;Port=5432;Database=AssistantEngineerTests;Username=postgres"
                          },
    "EnergyPlus":  {
                       "ExecutablePath":  "energyplus"
                   },
    "ApiHardening":  {
                         "Cors":  {
                                      "Enabled":  true,
                                      "PolicyName":  "ApiCors",
                                      "AllowedOrigins":  [
                                                             "http://localhost:5173",
                                                             "https://localhost:5173",
                                                             "http://localhost:3000",
                                                             "https://localhost:3000"
                                                         ],
                                      "AllowedMethods":  [
                                                             "GET",
                                                             "POST",
                                                             "PUT",
                                                             "PATCH",
                                                             "DELETE",
                                                             "OPTIONS"
                                                         ],
                                      "AllowedHeaders":  [
                                                             "Content-Type",
                                                             "Authorization",
                                                             "X-AssistantEngineer-Api-Key"
                                                         ]
                                  },
                         "RateLimiting":  {
                                               "Enabled":  false,
                                               "PermitLimit":  1000,
                                               "WindowSeconds":  60,
                                               "QueueLimit":  0,
                                               "AutoReplenishment":  true,
                                               "DefaultPolicyName":  "ApiDefault",
                                               "HeavyPolicyName":  "EngineeringHeavy",
                                               "HeavyPermitLimit":  1000,
                                               "HeavyWindowSeconds":  60
                                           }
                     },
    "Authentication":  {
                           "ApiKey":  {
                                          "Enabled":  false,
                                          "HeaderName":  "X-AssistantEngineer-Api-Key"
                                      }
                       },
    "EngineeringCalculationJobs":  {
                                       "Worker":  {
                                                      "Enabled":  false,
                                                      "PollIntervalSeconds":  5,
                                                      "BatchSize":  3
                                                  }
                                   }
}
