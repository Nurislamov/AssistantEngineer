@AssistantEngineer.Api_HostAddress = http://localhost:5194
@projectId = 1
@buildingId = 1
@floorId = 1
@roomId = 1
@wallId = 1
@windowId = 1
@thermalZoneId = 1
@climateZoneId = 1
@equipmentCatalogItemId = 1
@equipmentSystemType = Split
@equipmentUnitType = WallMounted

# Before running calculation/report requests:
# 1. Start PostgreSQL and apply EF migrations.
# 2. Create or seed a ClimateZone, then set @climateZoneId.
# 3. Create project -> building -> floor -> room, then set the IDs above.
# 4. Add at least one external wall before creating a window on that facade.
# 5. Import annual weather or seed ClimateData before Iso52016/energy-balance requests.

### Seed development demo data (Development environment only)
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/development/demo-data/seed
Accept: application/json

### Create project
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/projects
Content-Type: application/json

{
  "name": "Demo project"
}

### Get projects
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/projects?sortBy=name
Accept: application/json

### Update project
PUT {{AssistantEngineer.Api_HostAddress}}/api/v1/projects/{{projectId}}
Content-Type: application/json

{
  "name": "Demo project updated"
}

### Delete project
DELETE {{AssistantEngineer.Api_HostAddress}}/api/v1/projects/{{projectId}}

### Create building
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/projects/{{projectId}}/buildings
Content-Type: application/json

{
  "name": "Demo building",
  "climateZoneId": {{climateZoneId}}
}

### Get project buildings
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/projects/{{projectId}}/buildings?sortBy=name
Accept: application/json

### Get building
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}
Accept: application/json

### Update building
PUT {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}
Content-Type: application/json

{
  "name": "Demo building updated",
  "climateZoneId": {{climateZoneId}}
}

### Delete building
DELETE {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}

### Building readiness
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/readiness?weatherYear=2020
Accept: application/json

### Building validation
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/validation?weatherYear=2020
Accept: application/json

### Building validation autocorrection preview
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/validation/autocorrect-preview?weatherYear=2020
Content-Type: application/json

{
  "minimumRoomAreaM2": 1,
  "defaultRoomHeightM": 2.7,
  "maximumWindowToFloorAreaRatio": 0.8,
  "clampNegativePeopleCountToZero": true,
  "clampNegativeLoadsToZero": true,
  "removeUnexpectedAdjacentRoomReferences": true,
  "resizeOversizedWindows": true,
  "removeDuplicateThermalZoneAssignments": true,
  "applyRoomTypeInternalLoadDefaults": true,
  "applyPeopleCountDefaultsWhenMissing": true,
  "applyEquipmentLoadDefaultsWhenMissing": true,
  "applyLightingLoadDefaultsWhenMissing": true,
  "applyVentilationDefaultsWhenMissing": true
}

### Create floor
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/floors
Content-Type: application/json

{
  "name": "Level 1"
}

### Get building floors
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/floors?sortBy=name
Accept: application/json

### Update floor
PUT {{AssistantEngineer.Api_HostAddress}}/api/v1/floors/{{floorId}}
Content-Type: application/json

{
  "name": "Level 1 updated"
}

### Delete floor
DELETE {{AssistantEngineer.Api_HostAddress}}/api/v1/floors/{{floorId}}

### Create room
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms
Content-Type: application/json

{
  "name": "Office 101",
  "areaM2": 24,
  "heightM": 3,
  "indoorTemperatureC": 24,
  "outdoorTemperatureOverrideC": 35,
  "peopleCount": 3,
  "equipmentLoadW": 450,
  "lightingLoadW": 240,
  "type": "Office",
  "floorId": {{floorId}}
}

### Get building rooms
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/rooms?sortBy=name
Accept: application/json

### Get room
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}
Accept: application/json

### Update room
PUT {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}
Content-Type: application/json

{
  "name": "Office 101 updated",
  "areaM2": 28,
  "heightM": 3,
  "indoorTemperatureC": 23,
  "outdoorTemperatureOverrideC": 35,
  "peopleCount": 4,
  "equipmentLoadW": 520,
  "lightingLoadW": 280,
  "type": "Office"
}

### Delete room
DELETE {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}

### Add wall to room
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/walls
Content-Type: application/json

{
  "areaM2": 18,
  "uValue": 1.2,
  "orientation": "South",
  "boundaryType": "External",
  "adjacentRoomId": null
}

### Get room walls
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/walls?sortBy=orientation
Accept: application/json

### Update room wall
PUT {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/walls/{{wallId}}
Content-Type: application/json

{
  "areaM2": 20,
  "uValue": 0.9,
  "orientation": "South",
  "boundaryType": "External",
  "adjacentRoomId": null
}

### Delete room wall
DELETE {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/walls/{{wallId}}

### Add window to room
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/windows
Content-Type: application/json

{
  "areaM2": 4,
  "uValue": 2.1,
  "shgc": 0.55,
  "orientation": "South",
  "shading": {
    "overhangDepthM": 0.4,
    "sideFinDepthM": 0,
    "revealDepthM": 0.1,
    "windowHeightM": 1.4,
    "windowWidthM": 2,
    "minimumDirectSolarReductionFactor": 0.15,
    "diffuseSolarShareUnaffected": 0.3
  }
}

### Get room windows
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/windows?sortBy=orientation
Accept: application/json

### Update room window
PUT {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/windows/{{windowId}}
Content-Type: application/json

{
  "areaM2": 3.6,
  "uValue": 1.8,
  "shgc": 0.48,
  "orientation": "South",
  "shading": {
    "overhangDepthM": 0.5,
    "sideFinDepthM": 0,
    "revealDepthM": 0.1,
    "windowHeightM": 1.4,
    "windowWidthM": 2,
    "minimumDirectSolarReductionFactor": 0.15,
    "diffuseSolarShareUnaffected": 0.3
  }
}

### Delete room window
DELETE {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/windows/{{windowId}}

### Create thermal zone
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/thermal-zones
Content-Type: application/json

{
  "name": "Level 1 zone",
  "roomIds": [{{roomId}}]
}

### Get building thermal zones
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/thermal-zones?sortBy=name
Accept: application/json

### Update thermal zone
PUT {{AssistantEngineer.Api_HostAddress}}/api/v1/thermal-zones/{{thermalZoneId}}
Content-Type: application/json

{
  "name": "Level 1 zone updated",
  "roomIds": [{{roomId}}]
}

### Delete thermal zone
DELETE {{AssistantEngineer.Api_HostAddress}}/api/v1/thermal-zones/{{thermalZoneId}}

### Get room ventilation parameters
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/ventilation-parameters
Accept: application/json

### Upsert room ventilation parameters
PUT {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/ventilation-parameters
Content-Type: application/json

{
  "airChangesPerHour": 1.2,
  "heatRecoveryEfficiency": 0.65,
  "infiltrationAirChangesPerHour": 0.25,
  "windExposureFactor": 1,
  "stackCoefficient": 0.04,
  "windCoefficient": 0.12
}

### Delete room ventilation parameters
DELETE {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/ventilation-parameters

### Preview room ventilation defaults
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/ventilation-parameters/defaults
Accept: application/json

### Apply room ventilation defaults
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/ventilation-parameters/apply-defaults
Content-Type: application/json

{
  "overwriteExistingParameters": true
}

### Natural ventilation preview
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/natural-ventilation/preview
Content-Type: application/json

{
  "indoorTemperatureC": 24,
  "outdoorTemperatureC": 18,
  "windSpeedMPerS": 2.5,
  "demandFactor": 0.8,
  "hourOfDay": 14
}

### Get room ground contact
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/ground-contact
Accept: application/json

### Upsert room ground contact
PUT {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/ground-contact
Content-Type: application/json

{
  "contactType": "SlabOnGround",
  "exposedPerimeterM": 18,
  "burialDepthM": 0,
  "wallHeightBelowGradeM": 0,
  "horizontalInsulationWidthM": 0.6,
  "perimeterInsulationDepthM": 0.4,
  "underfloorVentilationAirChangesPerHour": 0
}

### Delete room ground contact
DELETE {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/ground-contact

### Import annual EPW weather
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/climate-zones/{{climateZoneId}}/annual-climate-data/epw
Content-Type: multipart/form-data; boundary=epw-boundary

--epw-boundary
Content-Disposition: form-data; name="year"

2020
--epw-boundary
Content-Disposition: form-data; name="sourceFile"; filename="demo.epw"
Content-Type: application/octet-stream

< ./weather/demo.epw
--epw-boundary--

### Import annual PVGIS weather
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/climate-zones/{{climateZoneId}}/annual-climate-data/pvgis
Content-Type: application/json

{
  "year": 2020,
  "latitude": 41.3111,
  "longitude": 69.2797,
  "startYear": 2005,
  "endYear": 2020,
  "useHorizon": true,
  "radiationDatabase": "PVGIS-SARAH3"
}

### Building cooling load
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/load-calculations/cooling-load?method=Iso52016
Accept: application/json

### Building heating load
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/load-calculations/heating-load?method=En12831
Accept: application/json

### Building energy balance
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/load-calculations/energy-balance?coolingMethod=Iso52016&heatingMethod=En12831
Accept: application/json

### Floor cooling load
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/floors/{{floorId}}/load-calculations/cooling-load?method=Iso52016
Accept: application/json

### Room cooling load
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/load-calculations/cooling-load?method=Iso52016
Accept: application/json

### Room heating load
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/load-calculations/heating-load?method=En12831
Accept: application/json

### Create cooling equipment catalog item
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/equipment-catalog
Content-Type: application/json

{
  "manufacturer": "Demo HVAC",
  "systemType": "{{equipmentSystemType}}",
  "unitType": "{{equipmentUnitType}}",
  "modelName": "DX-35",
  "nominalCoolingCapacityKw": 3.5,
  "isActive": true
}

### Get equipment catalog
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/equipment-catalog?systemType={{equipmentSystemType}}&isActive=true&sortBy=nominalCoolingCapacityKw
Accept: application/json

### Update cooling equipment catalog item
PUT {{AssistantEngineer.Api_HostAddress}}/api/v1/equipment-catalog/{{equipmentCatalogItemId}}
Content-Type: application/json

{
  "manufacturer": "Demo HVAC",
  "systemType": "{{equipmentSystemType}}",
  "unitType": "{{equipmentUnitType}}",
  "modelName": "DX-35 updated",
  "nominalCoolingCapacityKw": 4.2,
  "isActive": true
}

### Deactivate cooling equipment catalog item
DELETE {{AssistantEngineer.Api_HostAddress}}/api/v1/equipment-catalog/{{equipmentCatalogItemId}}

### Select room equipment
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/equipment-selection?method=Iso52016
Content-Type: application/json

{
  "systemType": "{{equipmentSystemType}}",
  "unitType": "{{equipmentUnitType}}"
}

### Cooling report JSON
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/reports/buildings/{{buildingId}}/cooling?method=Iso52016&systemType={{equipmentSystemType}}&unitType={{equipmentUnitType}}
Accept: application/json

### Cooling report Excel
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/reports/buildings/{{buildingId}}/cooling/excel?method=Iso52016&systemType={{equipmentSystemType}}&unitType={{equipmentUnitType}}
Accept: application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

### Heating report JSON
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/reports/buildings/{{buildingId}}/heating?method=En12831
Accept: application/json

### Energy balance Excel
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/reports/buildings/{{buildingId}}/energy-balance/excel?coolingMethod=Iso52016&heatingMethod=En12831
Accept: application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

### Export EnergyPlus IDF model
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/benchmarks/energyplus/buildings/{{buildingId}}/model
Content-Type: application/json

{
  "runName": "demo"
}

### Run EnergyPlus benchmark
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/benchmarks/energyplus
Content-Type: application/json

{
  "modelArtifactId": "demo-model.idf",
  "weatherArtifactId": "demo-weather.epw",
  "runName": "demo",
  "additionalArguments": []
}

### Verify internal calculation against EnergyPlus
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/benchmarks/buildings/{{buildingId}}/verify?method=Iso52016
Content-Type: application/json

{
  "weatherArtifactId": "demo-weather.epw",
  "runName": "demo-verify",
  "additionalArguments": []
}
