### Get room walls
GET {{host}}/api/rooms/{{roomId}}/walls
Accept: application/json

> {%
client.test("GET room walls returns external and internal walls", function () {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.length === 2, "Expected exactly two walls for created room");
    client.assert(response.body.some(function (wall) { return wall.isExternal === true; }), "Expected external wall");
    client.assert(response.body.some(function (wall) { return wall.isExternal === false; }), "Expected internal wall");
});
%}

### Calculate primary room with windows, walls, and internal heat gains
GET {{host}}/api/rooms/{{roomId}}/calculate
Accept: application/json

> {%
client.test("Calculate primary room returns complete heat load", function () {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.baseRoomLoadW === 3072, "Expected baseRoomLoadW 3072");
    client.assert(response.body.totalWindowAreaM2 === 5, "Expected totalWindowAreaM2 5");
    client.assert(response.body.windowHeatGainW === 1250, "Expected windowHeatGainW 1250");
    client.assert(response.body.totalWallAreaM2 === 30.5, "Expected totalWallAreaM2 30.5");
    client.assert(response.body.externalWallAreaM2 === 18.5, "Expected externalWallAreaM2 18.5");
    client.assert(response.body.wallHeatGainW === 1110, "Expected wallHeatGainW 1110");
    client.assert(response.body.peopleHeatGainW === 520, "Expected peopleHeatGainW 520");
    client.assert(response.body.equipmentHeatGainW === 900, "Expected equipmentHeatGainW 900");
    client.assert(response.body.lightingHeatGainW === 320, "Expected lightingHeatGainW 320");
    client.assert(response.body.internalHeatGainW === 1740, "Expected internalHeatGainW 1740");
    client.assert(response.body.deltaTemperatureC === 14, "Expected deltaTemperatureC 14");
    client.assert(response.body.heightAdjustmentFactor === 1, "Expected heightAdjustmentFactor 1");
    client.assert(response.body.temperatureAdjustmentFactor === 1.28, "Expected temperatureAdjustmentFactor 1.28");
    client.assert(response.body.totalHeatLoadW === 7172, "Expected totalHeatLoadW 7172");
    client.assert(response.body.totalHeatLoadKw === 7.17, "Expected totalHeatLoadKw 7.17");
    client.assert(response.body.designReserveFactor === 1.1, "Expected designReserveFactor 1.1");
    client.assert(response.body.designCapacityW === 7889.2, "Expected designCapacityW 7889.2");
    client.assert(response.body.designCapacityKw === 7.89, "Expected designCapacityKw 7.89");
});
%}

### Get primary room after calculation
GET {{host}}/api/rooms/{{roomId}}
Accept: application/json

> {%
client.test("GET primary room includes saved design capacity", function () {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.designReserveFactor === 1.1, "Expected saved designReserveFactor 1.1");
    client.assert(response.body.designCapacityW === 7889.2, "Expected saved designCapacityW 7889.2");
    client.assert(response.body.designCapacityKw === 7.89, "Expected saved designCapacityKw 7.89");
});
%}

### Create second room on the same floor for aggregate checks
POST {{host}}/api/rooms
Content-Type: application/json
Accept: application/json

{
  "name": "Small Office",
  "areaM2": 10,
  "heightM": 3.0,
  "indoorTemperatureC": 24,
  "outdoorTemperatureC": 24,
  "peopleCount": 1,
  "equipmentLoadW": 0,
  "lightingLoadW": 0,
  "floorId": {{floorId}}
}

> {%
client.test("Create second room returns 201", function () {
    client.assert(response.status === 201, "Expected 201 Created");
    client.assert(response.body.id > 0, "Expected generated room id");
    client.assert(response.body.floorId == client.global.get("floorId"), "Expected floorId");
});

client.global.set("secondRoomId", response.body.id);
%}

### Calculate second room
GET {{host}}/api/rooms/{{secondRoomId}}/calculate
Accept: application/json

> {%
client.test("Calculate second room returns expected simple heat load", function () {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.baseRoomLoadW === 1000, "Expected baseRoomLoadW 1000");
    client.assert(response.body.peopleHeatGainW === 130, "Expected peopleHeatGainW 130");
    client.assert(response.body.internalHeatGainW === 130, "Expected internalHeatGainW 130");
    client.assert(response.body.totalHeatLoadW === 1130, "Expected totalHeatLoadW 1130");
    client.assert(response.body.totalHeatLoadKw === 1.13, "Expected totalHeatLoadKw 1.13");
    client.assert(response.body.designReserveFactor === 1.1, "Expected designReserveFactor 1.1");
    client.assert(response.body.designCapacityW === 1243, "Expected designCapacityW 1243");
    client.assert(response.body.designCapacityKw === 1.24, "Expected designCapacityKw 1.24");
});
%}
