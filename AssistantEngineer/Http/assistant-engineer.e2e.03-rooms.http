@host = http://localhost:5218
@missingProjectId = 999999
@missingBuildingId = 999999
@missingFloorId = 999999
@missingRoomId = 999999

# Run the assistant-engineer.e2e files in numeric order when a request depends on variables from earlier files.

### Health: get all rooms
GET {{host}}/api/rooms
Accept: application/json

> {%
client.test("GET rooms returns 200", function () {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(Array.isArray(response.body), "Expected array response");
});
%}

### Negative: get missing room
GET {{host}}/api/rooms/{{missingRoomId}}
Accept: application/json

> {%
client.test("GET missing room returns 404", function () {
    client.assert(response.status === 404, "Expected 404 Not Found");
});
%}

### Negative: calculate missing room
GET {{host}}/api/rooms/{{missingRoomId}}/calculate
Accept: application/json

> {%
client.test("Calculate missing room returns 404", function () {
    client.assert(response.status === 404, "Expected 404 Not Found");
});
%}

### Negative: invalid room validation
POST {{host}}/api/rooms
Content-Type: application/json
Accept: application/json

{
  "name": "A",
  "areaM2": 0,
  "heightM": 21,
  "indoorTemperatureC": -51,
  "outdoorTemperatureC": 101,
  "peopleCount": -1,
  "equipmentLoadW": -10,
  "lightingLoadW": -5,
  "floorId": 0
}

> {%
client.test("Invalid room returns 400", function () {
    client.assert(response.status === 400, "Expected 400 Bad Request");
});
%}

### Negative: create room for missing floor
POST {{host}}/api/rooms
Content-Type: application/json
Accept: application/json

{
  "name": "Ghost Room",
  "areaM2": 24,
  "heightM": 3.0,
  "indoorTemperatureC": 24,
  "outdoorTemperatureC": 38,
  "peopleCount": 4,
  "equipmentLoadW": 900,
  "lightingLoadW": 320,
  "floorId": {{missingFloorId}}
}

> {%
client.test("Room for missing floor returns 404", function () {
    client.assert(response.status === 404, "Expected 404 Not Found");
});
%}

### Create primary room with internal heat gains
POST {{host}}/api/rooms
Content-Type: application/json
Accept: application/json

{
  "name": "Load Lab",
  "areaM2": 24,
  "heightM": 3.0,
  "indoorTemperatureC": 24,
  "outdoorTemperatureC": 38,
  "peopleCount": 4,
  "equipmentLoadW": 900,
  "lightingLoadW": 320,
  "floorId": {{floorId}}
}

> {%
client.test("Create primary room returns 201 and created payload", function () {
    client.assert(response.status === 201, "Expected 201 Created");
    client.assert(response.body.id > 0, "Expected generated room id");
    client.assert(response.body.name === "Load Lab", "Expected room name");
    client.assert(response.body.volumeM3 === 72, "Expected volumeM3 72");
    client.assert(response.body.peopleCount === 4, "Expected peopleCount 4");
    client.assert(response.body.equipmentLoadW === 900, "Expected equipmentLoadW 900");
    client.assert(response.body.lightingLoadW === 320, "Expected lightingLoadW 320");
    client.assert(response.body.floorId == client.global.get("floorId"), "Expected floorId");
});

client.global.set("roomId", response.body.id);
%}

### Get created room
GET {{host}}/api/rooms/{{roomId}}
Accept: application/json

> {%
client.test("GET created room returns all room fields", function () {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.name === "Load Lab", "Expected room name");
    client.assert(response.body.areaM2 === 24, "Expected areaM2 24");
    client.assert(response.body.heightM === 3, "Expected heightM 3");
    client.assert(response.body.volumeM3 === 72, "Expected volumeM3 72");
    client.assert(response.body.indoorTemperatureC === 24, "Expected indoorTemperatureC 24");
    client.assert(response.body.outdoorTemperatureC === 38, "Expected outdoorTemperatureC 38");
    client.assert(response.body.peopleCount === 4, "Expected peopleCount 4");
    client.assert(response.body.equipmentLoadW === 900, "Expected equipmentLoadW 900");
    client.assert(response.body.lightingLoadW === 320, "Expected lightingLoadW 320");
    client.assert(response.body.floorId == client.global.get("floorId"), "Expected floorId");
});
%}

### Calculate primary room before windows and walls
GET {{host}}/api/rooms/{{roomId}}/calculate
Accept: application/json

> {%
client.test("Calculate primary room includes internal heat gains before envelope gains", function () {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.baseRoomLoadW === 3072, "Expected baseRoomLoadW 3072");
    client.assert(response.body.totalWindowAreaM2 === 0, "Expected no windows");
    client.assert(response.body.totalWallAreaM2 === 0, "Expected no walls");
    client.assert(response.body.peopleHeatGainW === 520, "Expected peopleHeatGainW 520");
    client.assert(response.body.equipmentHeatGainW === 900, "Expected equipmentHeatGainW 900");
    client.assert(response.body.lightingHeatGainW === 320, "Expected lightingHeatGainW 320");
    client.assert(response.body.internalHeatGainW === 1740, "Expected internalHeatGainW 1740");
    client.assert(response.body.totalHeatLoadW === 4812, "Expected totalHeatLoadW 4812");
    client.assert(response.body.totalHeatLoadKw === 4.81, "Expected totalHeatLoadKw 4.81");
    client.assert(response.body.designReserveFactor === 1.1, "Expected designReserveFactor 1.1");
    client.assert(response.body.designCapacityW === 5293.2, "Expected designCapacityW 5293.2");
    client.assert(response.body.designCapacityKw === 5.29, "Expected designCapacityKw 5.29");
});
%}

### Add window 1
POST {{host}}/api/rooms/{{roomId}}/windows
Content-Type: application/json
Accept: application/json

{
  "areaM2": 3.2
}

> {%
client.test("Add first window returns 200", function () {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.roomId == client.global.get("roomId"), "Expected window roomId");
    client.assert(response.body.areaM2 === 3.2, "Expected window areaM2 3.2");
});
%}

