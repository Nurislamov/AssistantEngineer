### Add external wall
POST {{host}}/api/rooms/{{roomId}}/walls
Content-Type: application/json
Accept: application/json

{
  "areaM2": 18.5,
  "isExternal": true
}

> {%
client.test("Add external wall returns 200", function () {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.roomId == client.global.get("roomId"), "Expected wall roomId");
    client.assert(response.body.areaM2 === 18.5, "Expected wall areaM2 18.5");
    client.assert(response.body.isExternal === true, "Expected external wall");
});
%}

### Add internal wall
POST {{host}}/api/rooms/{{roomId}}/walls
Content-Type: application/json
Accept: application/json

{
  "areaM2": 12,
  "isExternal": false
}

> {%
client.test("Add internal wall returns 200", function () {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.roomId == client.global.get("roomId"), "Expected wall roomId");
    client.assert(response.body.areaM2 === 12, "Expected wall areaM2 12");
    client.assert(response.body.isExternal === false, "Expected internal wall");
});
%}

