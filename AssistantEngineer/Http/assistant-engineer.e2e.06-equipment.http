@host = http://localhost:5218
@missingRoomId = 999999
@missingEquipmentId = 999999

# This file is self-contained and can be run independently.

### Prepare run-specific filter values
GET {{host}}/api/projects
Accept: application/json

> {%
client.test("Prepare equipment run variables", function () {
    client.assert(response.status === 200, "Expected 200 OK");
});

const suffix = String(Date.now()).slice(-8);
client.global.set("equipmentSystemType", "SplitE2E" + suffix);
client.global.set("equipmentUnitType", "WallE2E" + suffix);
client.global.set("equipmentUnsupportedSystemType", "VRFE2E" + suffix);
client.global.set("equipmentUnsupportedUnitType", "CassE2E" + suffix);
%}

### Create project for equipment flow
POST {{host}}/api/projects
Content-Type: application/json
Accept: application/json

{
  "name": "Equipment Flow Project"
}

> {%
client.test("Create equipment project returns 201", function () {
    client.assert(response.status === 201, "Expected 201 Created");
    client.assert(response.body.id > 0, "Expected generated project id");
});
client.global.set("equipmentProjectId", response.body.id);
%}

