### Create room for equipment flow
POST {{host}}/api/rooms
Content-Type: application/json
Accept: application/json

{
  "name": "Equipment Flow Room",
  "areaM2": 24,
  "heightM": 3.0,
  "indoorTemperatureC": 24,
  "outdoorTemperatureC": 38,
  "peopleCount": 4,
  "equipmentLoadW": 900,
  "lightingLoadW": 320,
  "floorId": {{equipmentFloorId}}
}

> {%
client.test("Create equipment room returns 201", function () {
    client.assert(response.status === 201, "Expected 201 Created");
    client.assert(response.body.id > 0, "Expected generated room id");
});
client.global.set("equipmentRoomId", response.body.id);
%}

