### Calculate room before equipment selection
GET {{host}}/api/rooms/{{equipmentRoomId}}/calculate
Accept: application/json

> {%
client.test("Calculate equipment room returns 200", function () {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.designCapacityKw > 0, "Expected positive designCapacityKw");
});
client.global.set("equipmentRoomDesignCapacityKw", response.body.designCapacityKw);
%}

### Negative: get missing equipment catalog item
GET {{host}}/api/equipment-catalog-items/{{missingEquipmentId}}
Accept: application/json

> {%
client.test("GET missing equipment catalog item returns 404", function () {
    client.assert(response.status === 404, "Expected 404 Not Found");
});
%}

### Create active equipment item below required capacity
POST {{host}}/api/equipment-catalog-items
Content-Type: application/json
Accept: application/json

{
  "manufacturer": "CoolTech",
  "systemType": "{{equipmentSystemType}}",
  "unitType": "{{equipmentUnitType}}",
  "modelName": "WM-7.5",
  "nominalCoolingCapacityKw": 7.5,
  "isActive": true
}

> {%
client.test("Create low-capacity equipment returns 201", function () {
    client.assert(response.status === 201, "Expected 201 Created");
    client.assert(response.body.id > 0, "Expected generated item id");
});
%}

### Create active equipment item that should be selected
POST {{host}}/api/equipment-catalog-items
Content-Type: application/json
Accept: application/json

{
  "manufacturer": "CoolTech",
  "systemType": "{{equipmentSystemType}}",
  "unitType": "{{equipmentUnitType}}",
  "modelName": "WM-8.0",
  "nominalCoolingCapacityKw": 8.0,
  "isActive": true
}

> {%
client.test("Create selectable equipment returns 201", function () {
    client.assert(response.status === 201, "Expected 201 Created");
    client.assert(response.body.id > 0, "Expected generated item id");
    client.assert(response.body.nominalCoolingCapacityKw === 8.0, "Expected nominalCoolingCapacityKw 8.0");
});
client.global.set("selectedEquipmentCatalogItemId", response.body.id);
%}

### Create inactive equipment item with larger capacity
POST {{host}}/api/equipment-catalog-items
Content-Type: application/json
Accept: application/json

{
  "manufacturer": "CoolTech",
  "systemType": "{{equipmentSystemType}}",
  "unitType": "{{equipmentUnitType}}",
  "modelName": "WM-10.0-INACTIVE",
  "nominalCoolingCapacityKw": 10.0,
  "isActive": false
}

> {%
client.test("Create inactive equipment returns 201", function () {
    client.assert(response.status === 201, "Expected 201 Created");
    client.assert(response.body.isActive === false, "Expected inactive item");
});
%}

### Get created equipment by id
GET {{host}}/api/equipment-catalog-items/{{selectedEquipmentCatalogItemId}}
Accept: application/json

> {%
client.test("GET equipment by id returns created item", function () {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.id == client.global.get("selectedEquipmentCatalogItemId"), "Expected selected item id");
    client.assert(response.body.systemType === client.global.get("equipmentSystemType"), "Expected run-specific systemType");
    client.assert(response.body.unitType === client.global.get("equipmentUnitType"), "Expected run-specific unitType");
});
%}

### Select equipment for equipment flow room
POST {{host}}/api/rooms/{{equipmentRoomId}}/select-equipment
Content-Type: application/json
Accept: application/json

{
  "systemType": "{{equipmentSystemType}}",
  "unitType": "{{equipmentUnitType}}"
}

> {%
client.test("Select equipment returns smallest suitable active item", function () {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.roomId == client.global.get("equipmentRoomId"), "Expected roomId");
    client.assert(response.body.selectedCatalogItemId == client.global.get("selectedEquipmentCatalogItemId"), "Expected selected catalog item id");
    client.assert(response.body.selectedModelName === "WM-8.0", "Expected selected model");
    client.assert(response.body.selectedNominalCoolingCapacityKw === 8.0, "Expected selected nominal capacity 8.0");
    client.assert(response.body.capacityReserveKw >= 0, "Expected non-negative capacity reserve");
});
%}

### Get building report with equipment selection
GET {{host}}/api/buildings/{{equipmentBuildingId}}/report?systemType={{equipmentSystemType}}&unitType={{equipmentUnitType}}
Accept: application/json

> {%
client.test("Building report with equipment selection includes selected room equipment", function () {
    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(response.body.equipmentSelectionRequested === true, "Expected equipment selection request");
    client.assert(response.body.requestedSystemType === client.global.get("equipmentSystemType"), "Expected requested system type");
    client.assert(response.body.requestedUnitType === client.global.get("equipmentUnitType"), "Expected requested unit type");
    client.assert(response.body.roomsWithSelectionCount === 1, "Expected one room with equipment");
    client.assert(response.body.roomsWithoutSelectionCount === 0, "Expected no rooms without equipment");
    client.assert(response.body.totalSelectedCapacityKw === 8.0, "Expected total selected capacity 8.0");
    client.assert(response.body.rooms.length === 1, "Expected one room row");

    var room = response.body.rooms[0];
    client.assert(room.roomId == client.global.get("equipmentRoomId"), "Expected report room id");
    client.assert(room.requestedSystemType === client.global.get("equipmentSystemType"), "Expected room requested system type");
    client.assert(room.requestedUnitType === client.global.get("equipmentUnitType"), "Expected room requested unit type");
    client.assert(room.equipmentSelected === true, "Expected selected equipment");
    client.assert(room.selectedCatalogItemId == client.global.get("selectedEquipmentCatalogItemId"), "Expected selected catalog item id");
    client.assert(room.selectedModelName === "WM-8.0", "Expected selected model");
    client.assert(room.selectedNominalCoolingCapacityKw === 8.0, "Expected selected nominal capacity");
    client.assert(room.selectionReserveKw >= 0, "Expected non-negative selection reserve");
});
%}

### Download building Excel report with equipment selection
GET {{host}}/api/buildings/{{equipmentBuildingId}}/report/excel?systemType={{equipmentSystemType}}&unitType={{equipmentUnitType}}
Accept: application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

> {%
client.test("Download building Excel report with equipment selection returns xlsx file", function () {
    var contentType = String(response.headers.valueOf("Content-Type") || "");

    client.assert(response.status === 200, "Expected 200 OK");
    client.assert(contentType.indexOf("application/vnd.openxmlformats-officedocument.spreadsheetml.sheet") >= 0, "Expected xlsx content type, got " + contentType);
});
%}

### Negative: select equipment for unsupported filters
POST {{host}}/api/rooms/{{equipmentRoomId}}/select-equipment
Content-Type: application/json
Accept: application/json

{
  "systemType": "{{equipmentUnsupportedSystemType}}",
  "unitType": "{{equipmentUnsupportedUnitType}}"
}

> {%
client.test("Select equipment with unsupported filters returns 404", function () {
    client.assert(response.status === 404, "Expected 404 Not Found");
    client.assert(response.body === "No suitable equipment found for the specified room and filters.", "Expected no-suitable-equipment message");
});
%}

### Negative: select equipment for missing room
POST {{host}}/api/rooms/{{missingRoomId}}/select-equipment
Content-Type: application/json
Accept: application/json

{
  "systemType": "{{equipmentSystemType}}",
  "unitType": "{{equipmentUnitType}}"
}

> {%
client.test("Select equipment for missing room returns 404", function () {
    client.assert(response.status === 404, "Expected 404 Not Found");
    client.assert(String(response.body).indexOf("Room with id") >= 0, "Expected missing-room message");
});
%}
