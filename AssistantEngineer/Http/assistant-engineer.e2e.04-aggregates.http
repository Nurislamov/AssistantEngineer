### Setup: create primary room with envelope and internal loads
POST {{host}}/api/rooms
Content-Type: application/json
Accept: application/json

{
  "name": "Load Lab",
  "areaM2": 24,
  "heightM": 3.0,
  "indoorTemperatureC": 24,
  "outdoorTemperatureC": 38,
  "peopleCount": 4,
  "equipmentLoadW": 900,
  "lightingLoadW": 320,
  "floorId": {{floorId}}
}

> {%
client.test("Setup primary room for aggregates returns 201", function () {
    client.assert(response.status === 201, "Expected 201 Created");
    client.assert(response.body.id > 0, "Expected generated room id");
});
client.global.set("roomId", response.body.id);
%}

