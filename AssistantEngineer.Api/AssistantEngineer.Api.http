@AssistantEngineer.Api_HostAddress = http://localhost:5194
@projectId = 1
@buildingId = 1
@floorId = 1
@roomId = 1
@climateZoneId = 1
@equipmentSystemType = Split
@equipmentUnitType = WallMounted

# Before running calculation/report requests:
# 1. Start the API with a configured PostgreSQL connection string.
#    Development fallback is in appsettings.Development.json and can be overridden with:
#    $env:ConnectionStrings__DefaultConnection = "Host=localhost;Port=5432;Database=AssistantEngineerDb;Username=postgres;Password=<local-password>"
# 2. Run EF migrations for the configured database.
# 3. Seed calculation reference data with the SQL examples below. The API does not expose HTTP create
#    endpoints for these tables yet.
# 4. Create project -> building -> floor -> room before using calculation/report endpoints,
#    then set @projectId, @buildingId, @floorId, and @roomId to existing IDs.

### Seed ClimateZone
# Run in the configured PostgreSQL database before "Create building".
# Replace @climateZoneId above with the returned Id.
#
# INSERT INTO "ClimateZones" (
#   "Name",
#   "SummerDesignTemperatureC",
#   "WinterDesignTemperatureC"
# )
# VALUES (
#   'Tashkent design climate',
#   35,
#   -5
# )
# RETURNING "Id";

### Seed ClimateData
# Run after creating a ClimateZone. Iso52016 calculation endpoints require month 7 and all hours 0-23.
# Replace {{climateZoneId}} with the ClimateZone Id if your SQL client does not resolve .http variables.
#
# WITH climate_data AS (
#   INSERT INTO "ClimateData" (
#     "ClimateZoneId",
#     "Month",
#     "DayOfMonth",
#     "DailyTemperatureRange"
#   )
#   VALUES (
#     {{climateZoneId}},
#     7,
#     15,
#     10
#   )
#   ON CONFLICT ("ClimateZoneId", "Month") DO UPDATE SET
#     "DayOfMonth" = EXCLUDED."DayOfMonth",
#     "DailyTemperatureRange" = EXCLUDED."DailyTemperatureRange"
#   RETURNING "Id"
# ),
# hours AS (
#   SELECT
#     h AS "Hour",
#     30 + 4 * sin((h - 8) * pi() / 12) AS "DryBulbTemperature",
#     GREATEST(0, 700 * sin((h - 6) * pi() / 12)) AS "DirectSolarRadiation",
#     CASE WHEN h BETWEEN 6 AND 18 THEN 90 ELSE 0 END AS "DiffuseSolarRadiation"
#   FROM generate_series(0, 23) AS hours(h)
# )
# INSERT INTO "HourlyClimateData" (
#   "ClimateDataId",
#   "Hour",
#   "DryBulbTemperature",
#   "DirectSolarRadiation",
#   "DiffuseSolarRadiation"
# )
# SELECT
#   climate_data."Id",
#   hours."Hour",
#   hours."DryBulbTemperature",
#   hours."DirectSolarRadiation",
#   hours."DiffuseSolarRadiation"
# FROM climate_data
# CROSS JOIN hours
# ON CONFLICT ("ClimateDataId", "Hour") DO UPDATE SET
#   "DryBulbTemperature" = EXCLUDED."DryBulbTemperature",
#   "DirectSolarRadiation" = EXCLUDED."DirectSolarRadiation",
#   "DiffuseSolarRadiation" = EXCLUDED."DiffuseSolarRadiation"
# RETURNING "ClimateDataId";

### Seed ThermalZone
# Run after creating project -> building -> floor -> room. Use room IDs that belong to the same building.
# Replace {{buildingId}} and {{roomId}} with numeric IDs if your SQL client does not resolve .http variables.
#
# WITH zone AS (
#   INSERT INTO "ThermalZones" (
#     "Name",
#     "BuildingId"
#   )
#   VALUES (
#     'Level 1 thermal zone',
#     {{buildingId}}
#   )
#   RETURNING "Id"
# )
# INSERT INTO "ThermalZoneRooms" (
#   "ThermalZoneId",
#   "RoomId"
# )
# SELECT
#   zone."Id",
#   {{roomId}}
# FROM zone
# RETURNING "ThermalZoneId";

### Create project
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/projects
Content-Type: application/json

{
  "name": "Demo project"
}

### Get projects
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/projects
Accept: application/json

### Create building
# Requires @projectId from an existing project.
# climateZoneId must reference a pre-seeded ClimateZones row; EN 12831 and annual energy balance validate this.
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/projects/{{projectId}}/buildings
Content-Type: application/json

{
  "name": "Demo building",
  "climateZoneId": {{climateZoneId}}
}

### Create floor
# Requires @buildingId from an existing building.
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/floors
Content-Type: application/json

{
  "name": "Level 1"
}

### Create room
# Requires @floorId from an existing floor.
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms
Content-Type: application/json

{
  "name": "Office 101",
  "areaM2": 24,
  "heightM": 3,
  "indoorTemperatureC": 24,
  "outdoorTemperatureC": 35,
  "peopleCount": 3,
  "equipmentLoadW": 450,
  "lightingLoadW": 240,
  "type": "Office",
  "floorId": {{floorId}}
}

### Add wall to room
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/walls
Content-Type: application/json

{
  "areaM2": 18,
  "isExternal": true,
  "uValue": 1.2,
  "orientation": "South"
}

### Add window to room
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/windows
Content-Type: application/json

{
  "areaM2": 4,
  "uValue": 2.1,
  "shgc": 0.55,
  "orientation": "South"
}

### Get room walls
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/walls
Accept: application/json

### Get room windows
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/windows
Accept: application/json

### Create cooling equipment catalog item
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/equipment-catalog
Content-Type: application/json

{
  "manufacturer": "Demo HVAC",
  "systemType": "{{equipmentSystemType}}",
  "unitType": "{{equipmentUnitType}}",
  "modelName": "DX-35",
  "nominalCoolingCapacityKw": 3.5,
  "isActive": true
}

### Get equipment catalog
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/equipment-catalog
Accept: application/json

### Select room equipment
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/select-equipment?method=Iso52016
Content-Type: application/json

{
  "systemType": "{{equipmentSystemType}}",
  "unitType": "{{equipmentUnitType}}"
}

### Calculation/report prerequisites
# All requests below assume:
# - @buildingId, @floorId, and @roomId point to existing entities created above or already present in the database.
# - The building has @climateZoneId assigned.
# - Iso52016 requests have complete ClimateData for that ClimateZone, month 7, hours 0-23.
# - ThermalZones were seeded separately if zone-level building/report output is needed.

### Cooling load for building
# Requires an existing building with ClimateZone, floors, rooms, walls/windows as needed.
# Iso52016 additionally requires complete ClimateData for month 7; ThermalZones are read only if pre-seeded.
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/cooling-load?method=Iso52016
Accept: application/json

### Cooling load for building with invalid method
# Should return 400 ValidationProblemDetails, not 500.
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/cooling-load?method=999
Accept: application/json

### Heating load for building
# Requires an existing building with ClimateZone and at least one room.
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/heating-load?method=En12831
Accept: application/json

### Cooling load for floor
# Iso52016 requires the floor building's ClimateZone and complete ClimateData for month 7.
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/floors/{{floorId}}/cooling-load?method=Iso52016
Accept: application/json

### Annual energy balance
# Requires the building ClimateZone. Iso52016 cooling still needs complete month 7 ClimateData;
# monthly balance output is produced for months that have ClimateData rows.
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/buildings/{{buildingId}}/energy-balance?coolingMethod=Iso52016&heatingMethod=En12831
Accept: application/json

### Import annual EPW weather for ISO 52016
# After this import, annual energy balance with coolingMethod=Iso52016 uses 8760 hourly weather records.
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/climate-zones/{{climateZoneId}}/annual-climate-data/epw
Content-Type: application/json

{
  "filePath": "D:\\EnergyPlus\\weather\\demo.epw",
  "year": 2020
}

### Annual energy balance Excel
# Requires the same prerequisites as the annual energy balance JSON endpoint.
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/reports/buildings/{{buildingId}}/energy-balance/excel?coolingMethod=Iso52016&heatingMethod=En12831
Accept: application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

### Cooling report
# Iso52016 requires ClimateData with all hours 0-23 for month 7.
# ThermalZones are included only when rows were seeded for this building.
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/reports/buildings/{{buildingId}}?method=Iso52016
Accept: application/json

### Heating report
# Requires an existing building with ClimateZone and rooms.
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/reports/buildings/{{buildingId}}/heating?method=En12831
Accept: application/json

### Cooling report Excel
# Requires the same prerequisites as the cooling report JSON endpoint.
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/reports/buildings/{{buildingId}}/excel?method=Iso52016
Accept: application/vnd.openxmlformats-officedocument.spreadsheetml.sheet

### Cooling load for room
# Iso52016 requires the room building's ClimateZone and ClimateData with all hours 0-23 for month 7.
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/cooling-load?method=Iso52016
Accept: application/json

### Heating load for room
# Requires the room's building to have a ClimateZone.
GET {{AssistantEngineer.Api_HostAddress}}/api/v1/rooms/{{roomId}}/heating-load?method=En12831
Accept: application/json

### Export EnergyPlus IDF model
# Requires an existing building with floors and rooms. The server creates and stores the model artifact.
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/benchmarks/energyplus/buildings/{{buildingId}}/model
Content-Type: application/json

{
  "runName": "demo"
}

### EnergyPlus validation run
# Requires EnergyPlus installed/configured and model/weather artifacts managed by the server.
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/benchmarks/energyplus
Content-Type: application/json

{
  "modelArtifactId": "demo-model.idf",
  "weatherArtifactId": "demo-weather.epw",
  "runName": "demo",
  "additionalArguments": []
}

### Verify internal calculation against EnergyPlus
# Requires EnergyPlus configuration and a server-managed weather artifact.
POST {{AssistantEngineer.Api_HostAddress}}/api/v1/benchmarks/buildings/{{buildingId}}/verify?method=Iso52016
Content-Type: application/json

{
  "weatherArtifactId": "demo-weather.epw",
  "runName": "demo-verify",
  "additionalArguments": []
}



